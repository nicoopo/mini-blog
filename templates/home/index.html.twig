{% extends 'base.html.twig' %}

{% block title %}Accueil{% endblock %}

{% block body %}
    <div class="container mt-5">
        <h1 class="mb-4">Derniers articles</h1>
        <div class="row">
            {% for article in articles %}
                <div class="col-md-4 mb-4">
                    <div class="card h-100">
                        {% if article.picture %}
                            <img src="{{ article.picture }}" class="card-img-top" alt="{{ article.title }}">
                        {% endif %}
                        <div class="card-body">
                            <h5 class="card-title">{{ article.title }}</h5>
                            <p class="card-text text-muted">
                                <small>{{ article.createdAt|date('d/m/Y') }} — {{ article.author }}</small>
                            </p>
                            <p class="card-text">{{ article.content|slice(0, 150) }}...</p>
                            <a href="{{ path('app_article_show', {id: article.id}) }}" class="btn btn-primary">Lire la suite</a>
                        </div>
                    </div>
                </div>
            {% else %}
                <p>Aucun article pour le moment.</p>
            {% endfor %}
        </div>
    </div>
{% endblock %}
