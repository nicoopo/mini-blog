{% extends 'base.html.twig' %}

{% block title %}Mon Profil{% endblock %}

{% block body %}
    <div class="container py-5">

        {# Infos utilisateur #}
        <div class="card mb-4">
            <div class="card-body d-flex align-items-center gap-4">
                {% if user.profilePicture %}
                    <img src="{{ asset('uploads/profiles/' ~ user.profilePicture) }}"
                         class="rounded-circle" width="100" height="100" style="object-fit:cover">
                {% else %}
                    <div class="rounded-circle bg-secondary d-flex align-items-center justify-content-center"
                         style="width:100px;height:100px;font-size:2rem;color:white">
                        {{ user.firstName|first }}{{ user.lastName|first }}
                    </div>
                {% endif %}

                <div>
                    <h2>{{ user.firstName }} {{ user.lastName }}</h2>
                    <p class="text-muted mb-1">@{{ user.username }}</p>
                    <p class="text-muted mb-1">{{ user.email }}</p>
                    <small class="text-muted">Membre depuis {{ user.createdAt|date('d/m/Y') }}</small>
                </div>
            </div>
        </div>

        {# Mes Articles #}
        <h4>Mes articles ({{ articles|length }})</h4>
        {% if articles is empty %}
            <p class="text-muted">Aucun article publié.</p>
        {% else %}
            <div class="list-group mb-4">
                {% for article in articles %}
                    <a href="{{ path('app_article_show', {id: article.id}) }}"
                       class="list-group-item list-group-item-action d-flex justify-content-between">
                        <span>{{ article.title }}</span>
                        <small class="text-muted">{{ article.createdAt|date('d/m/Y') }}</small>
                    </a>
                {% endfor %}
            </div>
        {% endif %}

        {# Mes Commentaires #}
        <h4>Mes commentaires ({{ comments|length }})</h4>
        {% if comments is empty %}
            <p class="text-muted">Aucun commentaire posté.</p>
        {% else %}
            <div class="list-group">
                {% for comment in comments %}
                    <div class="list-group-item">
                        <p class="mb-1">{{ comment.content }}</p>
                        <small class="text-muted">
                            Sur : <a href="{{ path('app_article_show', {id: comment.article.id}) }}">
                                {{ comment.article.title }}
                            </a>
                            — {{ comment.createdAt|date('d/m/Y') }}
                        </small>
                    </div>
                {% endfor %}
            </div>
        {% endif %}
        <a href="{{ path('app_profile_edit') }}" class="btn btn-primary mt-2">Modifier mon profil</a>
    </div>
{% endblock %}
