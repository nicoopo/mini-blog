{% extends 'base.html.twig' %}

{% block title %}{{ article.title }}{% endblock %}

{% block body %}
<div class="container mt-5">

    <div class="mb-4">
        {% if article.picture %}
        <img src="{{ article.picture }}" class="img-fluid rounded mb-3" alt="{{ article.title }}">
        {% endif %}
        <h1>{{ article.title }}</h1>
        <p class="text-muted">
            <small>
                {{ article.createdAt|date('d/m/Y') }}
                {% if article.author %} — {{ article.author }}{% endif %}
                {% if article.category %} — {{ article.category }}{% endif %}
            </small>
        </p>
        <div class="article-content">
            {{ article.content|nl2br }}
        </div>
        <a href="{{ path('app_home') }}" class="btn btn-secondary mt-3">← Retour</a>
    </div>

    <hr>

    <h3>Commentaires ({{ comments|length }})</h3>

    {% for comment in comments %}
        <div class="card mb-3">
            <div class="card-body">
                <p class="mb-1">{{ comment.content }}</p>
                <small class="text-muted">
                    {{ comment.author }} — {{ comment.createdAt|date('d/m/Y H:i') }}
                </small>
            </div>
        </div>
    {% else %}
        <p>Aucun commentaire pour le moment.</p>
    {% endfor %}

    <hr>

    {% if is_granted('IS_AUTHENTICATED_FULLY') %}
        <h4>Laisser un commentaire</h4>

        {% for flash in app.flashes('success') %}
        <div class="alert alert-success">{{ flash }}</div>
        {% endfor %}

        {{ form_start(commentForm) }}
        {{ form_row(commentForm.content) }}
        <button type="submit" class="btn btn-primary mt-2">Envoyer</button>
        {{ form_end(commentForm) }}
    {% else %}
        <p>
            <a href="{{ path('app_login') }}">Connectez-vous</a> pour laisser un commentaire.
        </p>
    {% endif %}

</div>
{% endblock %}
